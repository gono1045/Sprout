<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.sprout.dao.SproutDao">

  <resultMap id="SproutItemMap" type="com.example.sprout.model.SproutItem">
    <id property="id" column="id" />
    <result property="title" column="title" />
    <result property="tag" column="tag" />
    <result property="status" column="status" />
    <result property="priority" column="priority" />
    <result property="createdAt" column="createdAt" />
    <result property="deadline" column="deadline" />
    <result property="detail" column="detail" />
    <result property="done" column="done" />
  </resultMap>

  <select id="findAll" resultMap="SproutItemMap">
    SELECT * FROM sprout_item ORDER BY created_at ASC
  </select>

  <select id="findById" parameterType="long" resultMap="SproutItemMap">
    SELECT * FROM sprout_item WHERE id = #{id}
  </select>

  <insert id="insert" parameterType="com.example.sprout.model.SproutItem">
    INSERT INTO sprout_item (title, tag, status, priority, created_at, deadline, detail, done)
    VALUES (#{title}, #{tag}, #{status}, #{priority}, #{createdAt}, #{deadline}, #{detail}, #{done})
  </insert>

  <update id="update" parameterType="com.example.sprout.model.SproutItem">
    UPDATE sprout_item
    SET title=#{title}, tag=#{tag}, status=#{status}, priority=#{priority},
      created_at=#{createdAt}, deadline=#{deadline}, detail=#{detail}, done=#{done}
    WHERE id=#{id}
  </update>

  <delete id="delete" parameterType="long">
    DELETE FROM sprout_item WHERE id=#{id}
  </delete>

</mapper>