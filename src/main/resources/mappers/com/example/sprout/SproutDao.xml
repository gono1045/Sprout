<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.sprout.dao.SproutDao">

  <resultMap id="SproutItemMap" type="com.example.sprout.model.SproutItem">
    <id property="id" column="id" />
    <result property="title" column="title" />
    <result property="status" column="status" />
    <result property="priority" column="priority" />
    <result property="createdAt" column="created_at" />
    <result property="deadline" column="deadline" />
    <result property="detail" column="detail" />
    <result property="done" column="done" />
  </resultMap>

  <select id="findAll" resultMap="SproutItemMap">
    SELECT * FROM sprout_item ORDER BY created_at ASC
  </select>

  <select id="findById" parameterType="long" resultMap="SproutItemMap">
    SELECT * FROM sprout_item WHERE id = #{id}
  </select>

  <insert id="insert" parameterType="com.example.sprout.model.SproutItem">
    INSERT INTO sprout_item (title, status, priority, created_at, deadline, detail, done)
    VALUES (#{title}, #{status}, #{priority}, #{createdAt}, #{deadline}, #{detail}, #{done})
  </insert>

  <update id="update" parameterType="com.example.sprout.model.SproutItem">
    UPDATE sprout_item
    SET title=#{title}, status=#{status}, priority=#{priority},
      created_at=#{createdAt}, deadline=#{deadline}, detail=#{detail}, done=#{done}
    WHERE id=#{id}
  </update>

  <delete id="delete" parameterType="long">
    DELETE FROM sprout_item WHERE id=#{id}
  </delete>

  <!-- tag ResultMap -->
  <resultMap id="SproutTagMap" type="com.example.sprout.model.SproutTag">
    <id property="tagId" column="tag_id" />
    <result property="tagName" column="tag_name" />
    <result property="tagDetail" column="tag_detail" />
    <result property="tagColor" column="tag_color" />
    <result property="tagSortOrder" column="tag_sort_order" />
    <result property="parentTagId" column="parent_tag_id" />
  </resultMap>

  <select id="findAllTags" resultMap="SproutTagMap">
    SELECT * FROM tags ORDER BY tag_sort_order ASC
  </select>

  <select id="findTagById" parameterType="long" resultMap="SproutTagMap">
    SELECT *
    FROM tags
    WHERE tag_id = #{tagId}
  </select>

  <insert id="insertTag" parameterType="com.example.sprout.model.SproutTag">
    INSERT INTO tags (tag_name, tag_detail, tag_color, tag_sort_order, parent_tag_id)
    VALUES (#{tagName}, #{tagDetail}, #{tagColor}, #{tagSortOrder}, #{parentTagId})
  </insert>

  <update id="updateTag" parameterType="com.example.sprout.model.SproutTag">
    UPDATE tags
    SET tag_name=#{tagName}, tag_detail=#{tagDetail}, tag_color=#{tagColor}, tag_sort_order=#{tagSortOrder},
      parent_tag_id=#{parentTagId}
    WHERE tag_id=#{tagId}
  </update>

  <delete id="deleteTag" parameterType="long">
    DELETE FROM tags WHERE tag_id=#{tagId}
  </delete>

  <!-- SproutItemTag -->
<resultMap id="SproutItemTagMap" type="com.example.sprout.model.SproutItemTag">
  <id property="id" column="id" />
  <association property="tag" javaType="com.example.sprout.model.SproutTag" resultMap="SproutTagMap" column="tag_id"/>
</resultMap>

  <select id="findTagsByItemId" parameterType="long" resultMap="SproutItemTagMap">
    SELECT it.id, it.item_id, t.tag_id, t.tag_name
    FROM sprout_item_tag it
    JOIN tags t ON it.tag_id = t.tag_id
    WHERE it.item_id = #{id}
  </select>

  <insert id="insertItemTag" parameterType="com.example.sprout.model.SproutItemTag">
  INSERT INTO sprout_item_tag (item_id, tag_id)
  VALUES (#{item.id}, #{tag.tagId})
</insert>

  <delete id="deleteItemTagsByItemId" parameterType="long">
  DELETE FROM sprout_item_tag WHERE item_id = #{id}
</delete>

</mapper>